{
  "name": "laravel/laravel",
  "type": "project",
  "description": "The skeleton application for the Laravel framework.",
  "keywords": [
    "laravel",
    "framework"
  ],
  "license": "MIT",
  "require": {
    "php": "^8.3",
    "ext-intl": "*",
    "classid/laravel-service-query-builder-extend": "^1.7.0",
    "classid/template-replacement": "^1.1.1",
    "dentro/laravel-patcher": "^1.4.3",
    "dentro/yalr": "^1.5",
    "koffinate/laravel-menu": "^2.1.1",
    "laravel/framework": "^11.45.1",
    "laravel/horizon": "^5.33.0",
    "laravel/sanctum": "^4.1.1",
    "laravel/tinker": "^2.10.1",
    "league/flysystem-aws-s3-v3": "^3.29",
    "maatwebsite/excel": "^3.1.64",
    "sentry/sentry-laravel": "^4.14.1",
    "spatie/laravel-medialibrary": "^11.13.0",
    "spatie/laravel-permission": "^6.19",
    "veelasky/laravel-hashid": "^3.1.4",
    "yajra/laravel-datatables": "^11.0"
  },
  "require-dev": {
    "beyondcode/laravel-dump-server": "^2.1",
    "fakerphp/faker": "^1.24.1",
    "laravel-lang/common": "^6.7",
    "laravel/breeze": "^2.3.6",
    "laravel/pint": "^1.22.1",
    "laravel/sail": "^1.43.1",
    "mockery/mockery": "^1.6.12",
    "nunomaduro/collision": "^8.5",
    "pestphp/pest": "^2.36.0",
    "pestphp/pest-plugin-laravel": "^2.4",
    "symfony/browser-kit": "^7.3.0",
    "symfony/contracts": "^3.6",
    "symfony/http-client": "^7.3.0"
  },
  "repositories": [
    {
      "type": "vcs",
      "url": "git@github.com:classid/template-replacement.git"
    }, {
      "type": "vcs",
      "url": "git@github.com:classid/laravel-service-query-builder-extend.git"
    }
  ],
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Base\\": "base/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    },
    "files": [
      "app/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ],
    "post-update-cmd": [
      "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
    ],
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-create-project-cmd": [
      "@php artisan key:generate --ansi",
      "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
      "@php artisan migrate --graceful --ansi"
    ]
  },
  "extra": {
    "laravel": {
      "dont-discover": []
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "php-http/discovery": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
