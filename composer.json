{
    "name": "classid/umrah-haji",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": [
      "framework",
      "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "browner12/helpers": "^3.4",
        "dentro/laravel-concerns": "dev-master",
        "dentro/yalr": "^1.2",
        "guzzlehttp/guzzle": "^7.2",
        "laravel/breeze": "^1.14",
        "laravel/framework": "^9.32",
        "laravel/octane": "^1.3",
        "laravel/passport": "^11.2",
        "laravel/tinker": "^2.7",
        "maatwebsite/excel": "^3.1",
        "psr/simple-cache": "2.0",
        "spatie/laravel-medialibrary": "^10.5",
        "spatie/laravel-permission": "^5.5",
        "spiral/roadrunner": "^2.11",
        "vinkla/hashids": "^10.0"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.7",
        "barryvdh/laravel-ide-helper": "^2.12",
        "beyondcode/laravel-dump-server": "^1.8",
        "beyondcode/laravel-query-detector": "^1.6",
        "fakerphp/faker": "^1.9.1",
        "laravel/pint": "^1.0",
        "laravel/sail": "^1.0.1",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^6.1",
        "phpunit/phpunit": "^9.5.10",
        "spatie/laravel-ignition": "^1.0",
        "theanik/laravel-more-command": "^1.3"
    },
    "autoload": {
      "psr-4": {
        "App\\": "app/",
        "Database\\Factories\\": "database/factories/",
        "Database\\Seeders\\": "database/seeders/"
      },
      "files": [
        "app/helpers.php"
      ]
    },
    "autoload-dev": {
      "psr-4": {
        "Tests\\": "tests/"
      }
    },
    "scripts": {
      "post-autoload-dump": [
        "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
        "@php artisan package:discover --ansi"
      ],
      "post-update-cmd": [
        "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
      ],
      "post-root-package-install": [
        "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
      ],
      "post-create-project-cmd": [
        "@php artisan key:generate --ansi"
      ]
    },
    "extra": {
      "laravel": {
        "dont-discover": []
      }
    },
    "config": {
      "optimize-autoloader": true,
      "preferred-install": "dist",
      "sort-packages": true,
      "allow-plugins": {
        "pestphp/pest-plugin": true
      }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
  }
